#lang beagle/js
;; ⚠️ WIP / BLOCKED (2026-06-21) — structural drawSnapshot conversion in place, but
;; the text-rect ENUMERATE pass still uses Marionette CONTENT context, which discards
;; ("Browsing context has been discarded") on ANY gjoa-loaded page in headless —
;; independent of dark mode (off discards too), the nav mechanism (chrome loadURI
;; discards too), and the darkmode actor (gated, still discards). It's a general
;; gjoa-content + Marionette-content-context incompatibility, NOT a product defect
;; (the product renders — validated by the 11/0 drawSnapshot suite + smoke). See
;; [[project_darkmode_marionette_content_ctx_limit]]. PATH FORWARD: enumerate text
;; rects without a Marionette content handle — a content frame-script / JSActor query
;; (the content PROCESS is alive, only the WebDriver handle detaches), or bake known
;; text rects into the fixtures (as the /dark white-probe does). Network lane only.
;;
;; Dark-mode contrast-regression harness (#55) — the no-mistakes gate.
;;
;; For each golden fixture it drives the REAL binary in the production dark-mode
;; config (enabled + mode="hybrid"), then measures whether text is actually
;; legible on the RENDERED result:
;;   1. navigate (chrome-side progress listener) + settle (actor round-trip + paint)
;;   2. enumerate visible text runs in content (Range.getClientRects, page-relative)
;;   3. full-page screenshot (Marionette TakeScreenshot {:full true})
;;   4. for each text box: sample the composited backdrop (median pixel) AND the
;;      PAINTED glyph color (luminance extreme) — both painted, so the score reflects
;;      M3 (the paint-time text re-solve), which the computed CSS color cannot; WCAG
;;   5. score the page; assert passRatio >= the recorded baseline floor
;;
;; The contrast math (contrast-score) and sampling (contrast-sample) are pure and
;; unit-tested with zero binary; this file is the only part that needs a running
;; gjoa. Baselines start at 0 (record-only) and are ratcheted up to real floors
;; once measured on the binary (#63) — known-failing fixtures (mit-news) are
;; recorded so they can't regress further and prove the engine fix when they rise.
;;
;; Precondition: tools/test-driver/contrast-fixture-server.mjs serving :8976
;; (the runner --with-fixtures flag spawns it).
(ns gjoa.tests.integration.contrast
  (:require [gjoa.tests.dsl :refer [deftest expect sleep NAV-JS await-true wait-for]]
            [gjoa.tools.test-driver.contrast-score :refer [evaluate-box score-page]]
            [gjoa.tools.test-driver.contrast-sample :refer [decode-png sample-backdrop sample-foreground]]))
(define-mode strict)

(def BASE :- String "http://127.0.0.1:8976/")

;; Recorded contrast floors. 0 = record-only (always green, logs the score).
;; After the first binary run these become real floors via #63's measure step;
;; known-failing fixtures get a floor just below today's value so they can't
;; regress and visibly rise when the engine fix lands.
(def BASELINES :- Any
  {"mit-news" 0
   "hacker-news" 0
   "youtube" 0
   "wikipedia" 0
   "github" 0
   "editorial-card" 0
   "docs-codeblocks" 0
   "svg-logo" 0
   "dark-text-hero" 0})

;; Production dark-mode config (the default): master toggle on, hybrid mode (the
;; GjoaDarkmode actor inverts themeless-light docs per-document).
(def PREFS-JS :- String
  (str "Services.prefs.setBoolPref('gjoa.darkmode.enabled', true);"
       " Services.prefs.setCharPref('gjoa.darkmode.mode', 'hybrid');"
       " return 'on';"))

;; darkmode OFF — for the rect-enumeration pass. Content getComputedStyle works
;; pre-inversion, and page LAYOUT is inversion-invariant so the rects stay valid
;; for the inverted snapshot.
(def DARK-OFF-JS :- String
  (str "Services.prefs.setBoolPref('gjoa.darkmode.enabled', false);"
       " Services.prefs.setBoolPref('gjoa.darkmode.invert.enabled', false);"
       " return 'off';"))

;; Chrome-side full-page capture: drawSnapshot the document (w×h CSS px at dpr) into
;; an OffscreenCanvas, PNG-encode, base64. Replaces Marionette TakeScreenshot, which
;; needs a content WebDriver handle that engine inversion detaches ("discarded"). PNG
;; keeps the payload compact (raw full-page RGBA is too big to serialize back) and
;; feeds the EXISTING decode-png unchanged.
(defn snapshot-png-js [w :- Any h :- Any] :- String
  (str "const done = arguments[arguments.length-1];"
       "(async () => { try {"
       "  const win = Services.wm.getMostRecentWindow('navigator:browser');"
       "  const wg = win.gBrowser.selectedBrowser.browsingContext.currentWindowGlobal;"
       "  const scale = win.devicePixelRatio || 1;"
       "  const W = Math.max(1, Math.round(" w ")), H = Math.max(1, Math.round(" h "));"
       "  const bm = await wg.drawSnapshot(new win.DOMRect(0,0,W,H), scale, 'rgb(255,255,255)');"
       "  const cv = new win.OffscreenCanvas(Math.round(W*scale), Math.round(H*scale));"
       "  cv.getContext('2d').drawImage(bm,0,0);"
       "  const buf = new Uint8Array(await (await cv.convertToBlob({type:'image/png'})).arrayBuffer());"
       "  let s=''; for (let i=0;i<buf.length;i+=0x8000){ s += String.fromCharCode.apply(null, buf.subarray(i,i+0x8000)); }"
       "  done(win.btoa(s));"
       "} catch(e){ done('ERR:'+(e&&e.message||e)); } })();"))

;; Content-side enumeration: every visible text run -> page-relative box + its
;; post-inversion computed color + size/weight. Range.getClientRects (not the
;; element box) so we measure the text itself, not its padding. Capped at 400.
(def ENUMERATE-JS :- String
  (str "\n"
       "  const W = document.documentElement, boxes = [];\n"
       "  const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);\n"
       "  let n;\n"
       "  while ((n = walker.nextNode()) && boxes.length < 400) {\n"
       "    const t = (n.textContent || '').trim();\n"
       "    if (t.length < 2) continue;\n"
       "    const el = n.parentElement; if (!el) continue;\n"
       "    const cs = getComputedStyle(el);\n"
       "    if (cs.visibility === 'hidden' || cs.display === 'none' || parseFloat(cs.opacity) === 0) continue;\n"
       "    const range = document.createRange(); range.selectNodeContents(n);\n"
       "    for (const r of range.getClientRects()) {\n"
       "      if (r.width < 4 || r.height < 4 || r.bottom < 0 || r.right < 0) continue;\n"
       "      boxes.push({ x: r.left + window.scrollX, y: r.top + window.scrollY, w: r.width, h: r.height,\n"
       "        color: cs.color, fontSize: parseFloat(cs.fontSize),\n"
       "        bold: (parseInt(cs.fontWeight, 10) || 400) >= 600, text: t.slice(0, 40) });\n"
       "    }\n"
       "  }\n"
       "  return JSON.stringify({ boxes, pageWidth: W.scrollWidth, pageHeight: W.scrollHeight, dpr: window.devicePixelRatio });\n"))

;; Run the full measure flow for one fixture and assert its baseline floor.
(defn check-fixture [mn :- Any name :- String] :- Any
  (let [url (str BASE name)]
    ;; PASS 1 — darkmode OFF: navigate + enumerate text rects in CONTENT (works
    ;; pre-inversion). Layout is inversion-invariant, so these page-relative rects
    ;; stay valid for the inverted snapshot below.
    (js/await (.setContext mn "chrome"))
    (js/await (.executeScript mn DARK-OFF-JS))
    (js/await (.executeAsyncScript mn NAV-JS [url]))
    (js/await (sleep 500))
    (js/await (.setContext mn "content"))
    ;; await-true POLLS (wait-for catches errors + retries at 20ms) past the transient
    ;; post-navigation "Browsing context has been discarded" until the content doc is
    ;; ready; a one-shot executeScript here fails on that transient. Then enumerate.
    (await-true "return document.readyState === 'complete';" 8000)
    (let [meta (JSON/parse (js/await (.executeScript mn ENUMERATE-JS)))]
      ;; PASS 2 — enable production darkmode (hybrid) + re-navigate so the page
      ;; re-cascades INVERTED, then read the PAINTED result chrome-side (the metric
      ;; is now painted contrast — exactly what M3 guarantees).
      (js/await (.setContext mn "chrome"))
      (js/await (.executeScript mn PREFS-JS))
      (js/await (.executeAsyncScript mn NAV-JS [url]))
      (js/await (sleep 800))
      (let [page-w (.-pageWidth meta)
            shot (js/await (.executeAsyncScript mn (snapshot-png-js page-w (.-pageHeight meta)) []))
            _ (when (.startsWith shot "ERR:") (expect false (str name " drawSnapshot capture failed: " shot)))
            png (decode-png shot)
            scale (if (> page-w 0) (/ (:width png) page-w) 1)
            boxes (.-boxes meta)
            results (.map boxes
                      (fn [b :- Any] :- Any
                        (let [rect {:x (.-x b) :y (.-y b) :w (.-w b) :h (.-h b)}
                              bg (sample-backdrop png rect scale)
                              ;; PAINTED glyph (M3-aware), not the computed CSS color.
                              fg (sample-foreground png rect scale)]
                          (evaluate-box fg bg (.-fontSize b) (.-bold b) (.-text b)))))
            score (score-page results)
            ratio (:passRatio score)
            baseline (or (get BASELINES name) 0)]
        (console/log (str "\n[contrast] " name ": passRatio=" (.toFixed ratio 3)
                           " (" (:passes score) "/" (:total score) ") minRatio="
                           (.toFixed (:minRatio score) 2) " baseline=" baseline))
        (doseq [w (:worst5 score)]
          (when (not (:pass w))
            (console/log (str "    FAIL box ratio=" (.toFixed (:ratio w) 2)
                               " need=" (:thr w) " \"" (:text w) "\""))))
        (expect (>= ratio baseline)
                (str name " contrast regressed: passRatio " (.toFixed ratio 3) " < baseline " baseline))))))

(js/export (def tests :- Any
  [(deftest "contrast: mit-news (image-hero — the failing baseline)" [mn ctx] (js/await (check-fixture mn "mit-news")))
   (deftest "contrast: hacker-news (white/orange bars)" [mn ctx] (js/await (check-fixture mn "hacker-news")))
   (deftest "contrast: youtube (rounded image cards)" [mn ctx] (js/await (check-fixture mn "youtube")))
   (deftest "contrast: wikipedia (themeless-light, must invert clean)" [mn ctx] (js/await (check-fixture mn "wikipedia")))
   (deftest "contrast: github (native-dark capable)" [mn ctx] (js/await (check-fixture mn "github")))
   (deftest "contrast: editorial-card (text over image+gradient)" [mn ctx] (js/await (check-fixture mn "editorial-card")))
   (deftest "contrast: docs-codeblocks (small colored tokens)" [mn ctx] (js/await (check-fixture mn "docs-codeblocks")))
   (deftest "contrast: svg-logo (currentColor SVG text)" [mn ctx] (js/await (check-fixture mn "svg-logo")))
   (deftest "contrast: dark-text-hero (R3 regression vector)" [mn ctx] (js/await (check-fixture mn "dark-text-hero")))]))

(js/export-default tests)
