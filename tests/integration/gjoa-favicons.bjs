#lang beagle/js
;; #100: gjoa pages (new-tab, about:gjoa, about:sovereignty) must show the
;; sailboat favicon (chrome://gjoa/content/gjoa.svg), not Firefox's generic
;; globe placeholder. Opens each, lets the <link rel=icon> + the immediate
;; setIcon belt resolve, and asserts the tab's image is the sailboat.
(ns gjoa.tests.integration.gjoa-favicons
  (:require [gjoa.tests.dsl :refer [deftest chrome-eval await-true wait-for expect]]))
(define-mode strict)

(defn open-js [url :- String marker :- String] :- String
  (str "
    const p = Services.scriptSecurityManager.getSystemPrincipal();
    const t = gBrowser.addTab('" url "', { triggeringPrincipal: p });
    t.setAttribute('gjoa-test-marker', '" marker "');
    gBrowser.selectedTab = t;
    return true;"))

(defn icon-js [marker :- String] :- String
  (str "
    const t = [...gBrowser.tabs].find(x => x.getAttribute('gjoa-test-marker') === '" marker "');
    const img = (t && t.image) || '';
    if (t) { try { gBrowser.removeTab(t); } catch {} }
    return img;"))

(js/export (def tests :- Any
  [(deftest "about:gjoa shows the gjoa sailboat favicon" [mn]
     (await-true "return !!gBrowser;" 5000)
     (chrome-eval (open-js "about:gjoa" "fav-gjoa"))
     (await-true "const t = [...gBrowser.tabs].find(x => x.getAttribute('gjoa-test-marker') === 'fav-gjoa'); return !!(t && t.image && t.image.includes('gjoa.svg'));" 5000)
     (let [img (chrome-eval (icon-js "fav-gjoa"))]
       (expect (.includes img "gjoa.svg")
         (str "about:gjoa tab icon should be chrome://gjoa/content/gjoa.svg, got: " img))))

   (deftest "the gjoa new-tab page shows the sailboat favicon" [mn]
     (await-true "return !!gBrowser;" 5000)
     (chrome-eval (open-js "about:newtab" "fav-newtab"))
     (await-true "const t = [...gBrowser.tabs].find(x => x.getAttribute('gjoa-test-marker') === 'fav-newtab'); return !!(t && t.image && t.image.includes('gjoa.svg'));" 5000)
     (let [img (chrome-eval (icon-js "fav-newtab"))]
       (expect (.includes img "gjoa.svg")
         (str "new-tab tab icon should be chrome://gjoa/content/gjoa.svg, got: " img))))]))

(js/export-default tests)
