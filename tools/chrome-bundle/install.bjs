#lang beagle/js
;; Wire dist/chrome/ into the running gjoa install for dev-mode loading.
;;
;; Replaces the previous fx-autoconfig install (which dropped a loader into
;; the install root + scripts into a profile chrome/). With the native
;; loader baked into omni.ja, the only thing dev mode needs is a single
;; `<install_root>/gjoa-dev/` directory containing JS/ and CSS/
;; subdirectories. The loader (browser/components/gjoa/GjoaLoader.sys.mjs)
;; reads from there at startup.
;;
;; We use a SYMLINK rather than a copy:
;;   - Copy:    every iteration needs `bun run chrome:dist && bun run chrome:install`
;;   - Symlink: only `bun run chrome:dist` is needed; the install path
;;              transparently points at the freshly-rebuilt dist/.
;;
;; Trust note: the symlink target is owned by the current user (your repo
;; checkout). The install root for a dev build is also owned by the current
;; user, so this is the same trust boundary. For a production install (root-
;; owned install root), only root could create this symlink — end users
;; can't accidentally activate dev mode.
(ns gjoa.tools.chrome-bundle.install
  (:require [fs :refer [existsSync statSync]]
            [fs/promises :refer [rm symlink cp]]
            [path :refer [join]]
            [child_process :refer [spawnSync]]))
(define-mode strict)
(declare-extern [process] Any)

;; tools/chrome-bundle/install.ts used resolve(import.meta.dir, "..", "..")
;; to reach the repo root. Tools run via `bun run` from the repo root, so
;; cwd IS the repo root.
(def REPO-ROOT :- String (.cwd process))
(def DIST-CHROME :- String (join REPO-ROOT "dist" "chrome"))

(def REPO-OBJDIR :- String (join REPO-ROOT "engine" "obj-x86_64-pc-linux-gnu"))
(def ENV-OBJDIR :- Any (.-MOZ_OBJDIR (.-env process)))
(def MOZ-OBJDIR :- Any
  (if (and ENV-OBJDIR (.startsWith ENV-OBJDIR REPO-ROOT)) ENV-OBJDIR REPO-OBJDIR))
(def INSTALL-ROOT :- String (join MOZ-OBJDIR "dist" "bin"))
(def GJOA-DEV :- String (join INSTALL-ROOT "gjoa-dev"))

;; The LOOSE toolkit overlays (dark-mode actor + cosmetic actor + fixes JSON)
;; live at engine/toolkit/, which the objdir symlinks into dist/bin/modules/.
;; Only the heavy `gjoa import` refreshed them — `gjoa sync` (chrome:dist +
;; THIS) refreshed ONLY chrome bundles, so any src edit to these rotted in the
;; running mach binary until the next import. THAT is the recurring "youtube
;; went light again" / "my cosmetic fix didn't take" class: a chrome change
;; landed, a toolkit change silently didn't. Mirror them here so one `gjoa
;; sync` keeps chrome AND toolkit overlays current.
(def SRC-TOOLKIT :- String (join REPO-ROOT "src" "gjoa" "toolkit"))
(def ENG-TOOLKIT :- String (join REPO-ROOT "engine" "toolkit"))

;; GjoaLoader.bjs is the OTHER half of the same recurring class: it compiles to
;; engine/.../GjoaLoader.sys.mjs (symlinked live into the dev binary), but ONLY
;; `gjoa import`'s overlay step recompiled it — so a `gjoa sync` left the running
;; binary on a STALE loader (e.g. a newly-registered window actor never loads).
;; Recompile it here too, staleness-gated, so one `gjoa sync` is genuinely
;; complete: chrome bundles + toolkit overlays + the loader.
(def SRC-LOADER :- String
  (join REPO-ROOT "src" "gjoa" "browser" "components" "gjoa" "GjoaLoader.bjs"))
(def ENG-LOADER :- String
  (join REPO-ROOT "engine" "browser" "components" "gjoa" "GjoaLoader.sys.mjs"))
(def ENG-LOADER-STRAY :- String
  (join REPO-ROOT "engine" "browser" "components" "gjoa" "GjoaLoader.bjs"))
(def BEAGLE-BUILD :- String
  (join (or (.-BEAGLE_PIN_ROOT (.-env process))
            (join (.-HOME (.-env process)) "code" "beagle-pin"))
        "bin" "beagle-build"))

;; Recompile GjoaLoader.bjs → its .sys.mjs iff the source is newer (or output is
;; missing). Mirrors tools/prep/overlay.bjs' beagle-build invocation, incl. the
;; runtime-prefix remap Firefox's chrome ES loader needs.
(defn refresh-loader! [] :- Any
  (when (and (existsSync SRC-LOADER)
             (or (not (existsSync ENG-LOADER))
                 (> (.-mtimeMs (statSync SRC-LOADER)) (.-mtimeMs (statSync ENG-LOADER)))))
    (let [r (spawnSync "bash" [BEAGLE-BUILD SRC-LOADER ENG-LOADER]
                       {:cwd REPO-ROOT
                        :env (.assign Object {} (.-env process)
                               {"BEAGLE_JS_RUNTIME_PREFIX" "resource:///modules/gjoa/beagle/"})
                        :stdio "inherit"})]
      (when (not= (.-status r) 0)
        (console/error "✗ GjoaLoader.bjs recompile failed")
        (.exit process 1))
      (js/await (rm ENG-LOADER-STRAY {:force true}))
      (console/log "✓ recompiled GjoaLoader.bjs → engine (loader symlinked live into the dev binary)"))))

(defn main! [] :- Any
  (when (not (existsSync DIST-CHROME))
    (console/error "✗ dist/chrome/ not built — run `bun run chrome:dist` first")
    (.exit process 1))
  (when (not (existsSync INSTALL-ROOT))
    (console/error
      (str "✗ install root not found at " INSTALL-ROOT " — has gjoa been built "
           "via mach? (`cd engine && ./mach build`)"))
    (.exit process 1))

  ;; Replace any existing symlink/dir so re-runs are idempotent.
  (when (existsSync GJOA-DEV)
    (js/await (rm GJOA-DEV {:recursive true :force true})))
  (js/await (symlink DIST-CHROME GJOA-DEV "dir"))
  (console/log (str "✓ symlinked " DIST-CHROME " → " GJOA-DEV))

  ;; Refresh the loose toolkit overlays src → engine (the objdir symlinks read
  ;; them live). cp recursive+force MERGES into engine/toolkit, overwriting only
  ;; the files present in src; the rest of engine/toolkit is untouched.
  (when (existsSync SRC-TOOLKIT)
    (js/await (cp SRC-TOOLKIT ENG-TOOLKIT {:recursive true :force true}))
    (console/log (str "✓ synced loose toolkit overlays " SRC-TOOLKIT " → " ENG-TOOLKIT)))

  ;; Recompile the loader if its source moved (closes the last sync gap).
  (js/await (refresh-loader!))

  (console/log "\nLaunch:")
  (console/log (str "  " INSTALL-ROOT "/gjoa --no-remote --profile <profile_dir>"))
  (console/log "\nDaily loop: edit src/gjoa/chrome/bjs/* → `bun run chrome:dist` → restart gjoa."))

(js/await (main!))
